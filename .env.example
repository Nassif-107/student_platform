# MongoDB
MONGO_URI=mongodb://localhost:27017/student-platform

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=student-platform-secret

# InfluxDB
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=student-platform-influx-token
INFLUX_ORG=student-platform
INFLUX_BUCKET=metrics

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Node
NODE_ENV=development

# Frontend URL (used for CORS, email links)
FRONTEND_URL=http://localhost:3000

# SMTP (optional — uncomment to enable email delivery)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Student Platform <noreply@example.com>
